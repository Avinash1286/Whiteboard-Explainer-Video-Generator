# ─────────────────────────────────────────────────────────────
# Secrets — NEVER commit these
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
# Service-account / API keys (keep the JSON key OUTSIDE the repo)
*service-account*.json
*credentials*.json
*-key.json
gcp-*.json

# ─────────────────────────────────────────────────────────────
# Dependencies & build output
# ─────────────────────────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts
.convex/

# ─────────────────────────────────────────────────────────────
# Generated media & runtime artifacts
# ─────────────────────────────────────────────────────────────
outputs/

# Disk-backed caches that rebuild themselves at runtime
assets/generated/icon-query-cache.json
assets/generated/icon-choice-cache.json
assets/generated/icon-rerank-cache.json
assets/generated/excalidraw-query-cache.json
assets/generated/iconify/
assets/fonts/.fccache/

# Embedding indexes — large + regenerated by the build scripts (need a GCP key).
# See README "Build the asset library".
assets/vendor/openmoji/embeddings.bin
assets/vendor/openmoji/embeddings-meta.json
assets/vendor/excalidraw/embeddings.bin
assets/vendor/excalidraw/embeddings-meta.json
assets/vendor/openmoji/.build-progress.txt
assets/vendor/excalidraw/.build-progress.txt

# Excalidraw hand-drawn icon set (~190MB) — regenerate via scripts/excalidraw/*.
# Comment this out if you'd rather commit it (the app also works with OpenMoji only).
assets/vendor/excalidraw/

# ─────────────────────────────────────────────────────────────
# Local-only / internal (not for the public repo)
# ─────────────────────────────────────────────────────────────
video_analysis/
imp.md
simiarch.md
improvement-plan-lamina.md
.agents/
skills-lock.json

# ─────────────────────────────────────────────────────────────
# Editor / OS
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.log
.DS_Store
Thumbs.db
